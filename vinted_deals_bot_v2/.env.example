# ══════════════════════════════════════════════
# Vinted Deals Bot v2 — Configuration
# Copier en .env et remplir les valeurs
# ══════════════════════════════════════════════

# --- Vinted ---
VINTED_BASE_URL=https://www.vinted.fr
VINTED_COUNTRY=fr

# Mots-clés de recherche (séparés par des virgules)
KEYWORDS=pokemon,topps chrome,panini prizm,one piece tcg
KEYWORDS_PER_CYCLE=2
MAX_ITEMS_PER_KEYWORD=15

# Fourchette de prix (EUR)
MIN_PRICE=5
MAX_PRICE=150

# Mots exclus (lots, fakes, etc.)
EXCLUDE_WORDS=lot,bundle,x10,x20,x50,proxy,fake,repro,orica,custom,repack,mystery

# --- Proxy résidentiel (Decodo / Smartproxy / Bright Data) ---
PROXY_ENABLED=true
PROXY_HOST=gate.decodo.com
PROXY_PORT=10001
PROXY_USER=your_proxy_user
PROXY_PASS=your_proxy_pass

# --- Scoring ---
MIN_NET_MARGIN=0.25
SHIPPING_BUY=3.0
SHIPPING_SELL=3.0
PLATFORM_FEE_RATE=0.13
PAYMENT_FEE_RATE=0.03
PAYMENT_FEE_FIXED=0.35
MIN_SOLD_SAMPLES=3

# --- Alertes Telegram ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# --- Alertes Discord (optionnel) ---
DISCORD_WEBHOOK_URL=

# --- Comportement ---
CHECK_INTERVAL_SEC=300
DRY_RUN=true
ONE_SHOT=false
LOG_LEVEL=INFO
DB_PATH=deals.db
