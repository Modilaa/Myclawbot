# Runtime
ONE_SHOT=true
DRY_RUN=true
CHECK_INTERVAL_SEC=420

# Filters
MIN_NET_MARGIN=0.25
MIN_PRICE=10
MAX_PRICE=100

# Cost assumptions (adjust with your real fees)
SHIPPING_BUY=3.00
SHIPPING_SELL=3.00
EBAY_FEE_RATE=0.13
PAYMENT_FEE_RATE=0.03
PAYMENT_FEE_FIXED=0.35
ALERT_COOLDOWN_MIN=180

# Optional: Telegram direct API (if DRY_RUN=false)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Decodo Scraper API (required for Vinted bypass)
DECODO_BASIC_AUTH=
DECODO_USERNAME=
DECODO_PASSWORD=
DECODO_SCRAPER_URL=https://scraper-api.decodo.com/v2/scrape
MAX_ITEMS_PER_KEYWORD=20

# Vinted domain
VINTED_BASE=https://www.vinted.fr
COUNTRY_CODE=FR
